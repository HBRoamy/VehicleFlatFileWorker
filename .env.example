APP_NAME="Vehicle Data Handler"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# =====================================================================
# Database
# =====================================================================
# Production targets PostgreSQL. Set DB_CONNECTION=pgsql and the DB_* values
# (or provide them via the rotated secret consumed by vehicle:refresh-secrets).
# Local development can use the zero-setup SQLite option below.

# --- SQLite (zero-setup local dev) ---
DB_CONNECTION=sqlite
# DB_DATABASE defaults to database/database.sqlite when omitted for sqlite.

# --- PostgreSQL (production) ---
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=vehicles
# DB_USERNAME=postgres
# DB_PASSWORD=secret
# DB_SSLMODE=prefer

# Framework services (array/sync are fine for this CLI worker app).
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# =====================================================================
# Vehicle Data Handler
# =====================================================================

# --- Instance identity (owner recorded in the file lock table) ---
INSTANCE_ID=local-instance-01

# --- Driver selection ---
# local | sqs
VEHICLE_QUEUE_DRIVER=local
# local | s3
VEHICLE_STORAGE_DRIVER=local
# env | aws
VEHICLE_SECRETS_DRIVER=env

# --- Processing ---
# Worker concurrency cap AND the transactional batch size.
VEHICLE_MAX_PARALLELISM=10

# --- Polling / backoff ---
VEHICLE_POLL_INTERVAL=5
VEHICLE_EMPTY_POLL_THRESHOLD=60
VEHICLE_BACKOFF_SLEEP=300

# --- Secrets refresh ---
VEHICLE_ENABLE_REFRESH=true
VEHICLE_REFRESH_INTERVAL_HOURS=24

# --- File locking ---
VEHICLE_STALE_LOCK_TIMEOUT=30

# --- Local storage paths (defaults are fine) ---
# VEHICLE_LOCAL_PATH=/absolute/path/to/storage/app/incoming
# VEHICLE_LOCAL_QUEUE_PATH=/absolute/path/to/storage/app/queue

# --- Local secret map (used when VEHICLE_SECRETS_DRIVER=env) ---
VEHICLE_LOCAL_BUCKET=local-bucket
# VEHICLE_LOCAL_DB_DSN=host=127.0.0.1;port=5432;database=vehicles;username=postgres;password=secret

# --- Production AWS (only when using cloud drivers) ---
# AWS_DEFAULT_REGION=us-east-1
# VEHICLE_AWS_SECRET_ID=vehicle-data-handler
